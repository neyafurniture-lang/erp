# HTTPS automatique (Let's Encrypt) dès que le DNS pointe vers le VPS
{$ERP_DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:4000
	}

	handle /uploads/* {
		reverse_proxy backend:4000
	}

	handle /health {
		reverse_proxy backend:4000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
