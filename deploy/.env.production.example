# NEYA ERP — variables production (serveur VPS)
# Copier : cp deploy/.env.production.example .env.production

# --- Domaine & HTTPS (Caddy) ---
ERP_DOMAIN=erp.neyafurniture.ca
ACME_EMAIL=admin@neyafurniture.ca

# --- URLs publiques ---
FRONTEND_URL=https://erp.neyafurniture.ca
NEXT_PUBLIC_API_URL=https://erp.neyafurniture.ca/api

# --- Base de données ---
POSTGRES_PASSWORD=changez-moi-long-et-aleatoire

# --- Auth ERP ---
# openssl rand -hex 32
JWT_SECRET=
ADMIN_PASSWORD=

# --- Intégrations ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
WORDPRESS_URL=https://neyafurniture.ca
WOOCOMMERCE_KEY=
WOOCOMMERCE_SECRET=

# Google OAuth (Drive + Gmail) — peut aussi être configuré dans Paramètres → Intégrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Laisser vide : auto = FRONTEND_URL + /api/integrations/google/callback
GOOGLE_REDIRECT_URI=

# --- Déploiement Git (injectés par deploy.sh) ---
APP_VERSION=0.1.0
GIT_COMMIT=unknown

# --- Déploiement depuis l'ERP (Paramètres → Déploiement VPS) ---
# NEYA_GIT_REPO_URL=git@github.com:org/neya-erp.git
# NEYA_VPS_HOST=51.222.31.75
# NEYA_VPS_USER=ubuntu
# NEYA_VPS_SSH_KEY=/home/ubuntu/.ssh/id_ed25519
# NEYA_DEPLOY_BRANCH=main
# NEYA_REPO_DIR=/opt/neya-erp
